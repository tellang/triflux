# Logging (Logify)
LOG_LEVEL=debug          # trace | debug | info | warn | error | fatal
SERVICE_NAME=triflux     # 로그에 표시될 서비스 이름
NODE_ENV=development     # development | production

# Hub
TFX_HUB_PORT=27888
# TFX_HUB_TOKEN=         # 설정 시 Bearer 인증 활성화

# NPM
# NPM_TOKEN=             # npm publish용

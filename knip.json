{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "entry": ["bin/*.mjs", "scripts/*.mjs", "hub/**/*.mjs", "hud/**/*.mjs", "hooks/**/*.mjs"],
      "project": ["bin/**/*.mjs", "scripts/**/*.mjs", "hub/**/*.mjs", "hooks/**/*.mjs", "hud/**/*.mjs"]
    },
    "packages/core": {
      "entry": ["hub/**/*.mjs", "hud/**/*.mjs"],
      "project": ["hub/**/*.mjs", "hud/**/*.mjs"]
    },
    "packages/remote": {
      "entry": ["hub/**/*.mjs", "scripts/*.mjs"],
      "project": ["hub/**/*.mjs", "scripts/**/*.mjs"]
    },
    "packages/triflux": {
      "entry": ["bin/*.mjs", "scripts/*.mjs", "hub/**/*.mjs", "hooks/**/*.mjs"],
      "project": ["bin/**/*.mjs", "scripts/**/*.mjs", "hub/**/*.mjs", "hooks/**/*.mjs"]
    }
  },
  "ignore": ["research/**", "tests/**", "skills/**"]
}

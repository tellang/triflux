# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicit LF overrides for common source, data, docs, and shell files
*.mjs text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Binary files
*.ico binary
*.png binary
*.gif binary
*.db binary
*.node binary